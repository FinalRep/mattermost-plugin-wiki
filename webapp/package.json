{
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "webpack --mode=production",
    "build:watch": "webpack --mode=production --watch",
    "debug": "webpack --mode=development",
    "debug:watch": "webpack --mode=development --watch",
    "dev-server": "webpack serve --mode=development",
    "lint": "eslint --ignore-pattern node_modules --ignore-pattern dist --ext .js --ext .jsx --ext tsx --ext ts . --quiet --cache",
    "fix": "eslint --ignore-pattern node_modules --ignore-pattern dist --ext .js --ext .jsx --ext tsx --ext ts . --quiet --fix --cache",
    "test": "jest --forceExit --detectOpenHandles --verbose",
    "test:watch": "jest --watch",
    "test-ci": "jest --forceExit --detectOpenHandles --maxWorkers=2",
    "check-types": "tsc",
    "extract": "formatjs extract 'src/**/*.{ts,tsx}' --out-file i18n/temp.json --id-interpolation-pattern '[sha512:contenthash:base64:6]' && formatjs compile 'i18n/temp.json' --out-file i18n/en.json && rm i18n/temp.json"
  },
  "author": "",
  "license": "",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/plugin-proposal-optional-chaining": "7.21.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@formatjs/cli": "^6.2.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
    "@testing-library/react": "^14.0.0",
    "@types/classnames": "^2.3.1",
    "@types/debounce": "^1.2.4",
    "@types/history": "^4.7.11",
    "@types/jest": "29.5.0",
    "@types/lodash": "^4.14.200",
    "@types/luxon": "^3.3.0",
    "@types/qs": "^6.9.10",
    "@types/react": "^18.2.0",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-bootstrap": "^1.0.3",
    "@types/react-custom-scrollbars": "^4.0.13",
    "@types/react-dom": "^18.2.0",
    "@types/react-redux": "^7.1.33",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-select": "^5.0.1",
    "@types/react-test-renderer": "^18.0.0",
    "@types/redux-mock-store": "^1.0.6",
    "@types/shallow-equals": "^1.0.1",
    "@types/styled-components": "^5.1.34",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@webpack-cli/serve": "^2.0.5",
    "babel-eslint": "^10.1.0",
    "babel-jest": "29.7.0",
    "babel-loader": "^9.1.3",
    "babel-plugin-add-react-displayname": "^0.0.5",
    "babel-plugin-formatjs": "^10.5.10",
    "babel-plugin-styled-components": "^2.1.4",
    "babel-plugin-typescript-to-proptypes": "^2.1.0",
    "classnames": "^2.3.2",
    "css-loader": "^6.8.1",
    "eslint": "^8.54.0",
    "eslint-import-resolver-webpack": "^0.13.8",
    "eslint-plugin-formatjs": "^4.13.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "file-loader": "^6.2.0",
    "jest": "29.7.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "29.7.0",
    "jest-junit": "^16.0.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-bootstrap": "^2.9.0",
    "react-refresh": "^0.14.0",
    "react-test-renderer": "^18.2.0",
    "redux-mock-store": "^1.5.4",
    "redux-thunk": "^2.4.2",
    "sass": "^1.69.0",
    "sass-loader": "^13.3.0",
    "style-loader": "^3.3.3",
    "ts-jest": "29.4.6",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "5.2.3"
  },
  "dependencies": {
    "@apollo/client": "^3.8.0",
    "@floating-ui/react": "^0.26.0",
    "@mattermost/client": "^10.0.0",
    "@mattermost/compass-icons": "^0.1.43",
    "@mattermost/types": "10.12.0",
    "@mdi/js": "^7.3.67",
    "@mdi/react": "^1.6.1",
    "@tippyjs/react": "^4.2.6",
    "@uiw/react-md-editor": "4.0.11",
    "chrono-node": "^2.7.0",
    "core-js": "^3.33.0",
    "debounce": "^2.0.0",
    "lodash": "^4.17.21",
    "luxon": "^3.4.0",
    "mattermost-redux": "11.3.0",
    "parse-duration": "2.1.5",
    "qs": "^6.11.2",
    "react": "^18.2.0",
    "react-custom-scrollbars-2": "4.5.0",
    "react-dom": "^18.2.0",
    "react-infinite-scroll-component": "^6.1.0",
    "react-intl": "^6.5.0",
    "react-redux": "^8.1.0",
    "react-router-dom": "^5.3.4",
    "react-select": "^5.8.0",
    "react-use": "^17.4.2",
    "redux": "^4.2.1",
    "rehype-sanitize": "6.0.0",
    "reselect": "5.1.1",
    "styled-components": "^6.1.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": "babel-jest"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/non_npm_dependencies/"
    ],
    "testEnvironment": "jest-environment-jsdom",
    "clearMocks": true,
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}"
    ],
    "coverageReporters": [
      "lcov",
      "text-summary"
    ],
    "moduleNameMapper": {
      "^.+\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "identity-obj-proxy",
      "^.+\\.(css|less|scss)$": "identity-obj-proxy",
      "^.*i18n.*\\.(json)$": "<rootDir>/tests/i18n_mock.json",
      "^bundle-loader\\?lazy\\!(.*)$": "$1",
      "^mattermost-redux(.*)$": "@mattermost/client$1",
      "^@mattermost/types(.*)$": "@mattermost/types$1"
    },
    "moduleDirectories": [
      "<rootDir>",
      "node_modules",
      "non_npm_dependencies"
    ],
    "reporters": [
      "default",
      "jest-junit"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!react-native|react-router)"
    ],
    "setupFiles": [
      "jest-canvas-mock"
    ],
    "testEnvironmentOptions": {
      "url": "http://localhost:8065"
    }
  },
  "jest-junit": {
    "output": "build/test-results.xml"
  },
  "overrides": {
    "mattermost-redux": {
      "@mattermost/types": "$@mattermost/types"
    },
    "eslint-plugin-formatjs": {
      "@typescript-eslint/utils": "^7.18.0",
      "@typescript-eslint/typescript-estree": "^7.18.0",
      "minimatch": "^9.0.5"
    }
  }
}
